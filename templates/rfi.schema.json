{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://espaciocorp.cl/schemas/rfi.schema.json",
    "title": "RFI Document",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "project",
        "parties",
        "reference_documents",
        "rfi_description",
        "attachments",
        "dates",
        "signatures",
        "answer",
        "metadata"
    ],
    "properties": {
        "$schema": {
            "type": "string"
        },
        "project": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "project_no",
                "project_name",
                "client",
                "proposal_no",
                "rfi_no"
            ],
            "properties": {
                "project_no": {
                    "type": "string",
                    "minLength": 1
                },
                "project_name": {
                    "type": "string",
                    "minLength": 1
                },
                "client": {
                    "type": "string",
                    "minLength": 1
                },
                "proposal_no": {
                    "type": "string",
                    "pattern": "^[A-Za-z]{1,5}[0-9]{1,6}$"
                },
                "rfi_no": {
                    "type": "string",
                    "pattern": "^[0-9]{3}-[0-9]{3}$"
                }
            }
        },
        "parties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "to",
                "contractor",
                "from",
                "cc"
            ],
            "properties": {
                "to": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "company",
                        "department"
                    ],
                    "properties": {
                        "company": {
                            "type": "string",
                            "minLength": 1
                        },
                        "department": {
                            "type": "string",
                            "minLength": 1
                        }
                    }
                },
                "contractor": {
                    "type": "string",
                    "minLength": 1
                },
                "from": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "name",
                        "email"
                    ],
                    "properties": {
                        "name": {
                            "type": "string",
                            "minLength": 1
                        },
                        "email": {
                            "type": "string",
                            "format": "email"
                        }
                    }
                },
                "cc": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/personWithEmail"
                    }
                }
            }
        },
        "reference_documents": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "rfi_description": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "summary",
                "items"
            ],
            "properties": {
                "summary": {
                    "type": "string",
                    "minLength": 1
                },
                "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rfiItem"
                    }
                }
            }
        },
        "attachments": {
            "type": "object",
            "additionalProperties": true,
            "required": [
                "includes_documents"
            ],
            "properties": {
                "includes_documents": {
                    "type": "boolean"
                }
            }
        },
        "dates": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "origin_date",
                "answer_date",
                "return_date"
            ],
            "properties": {
                "origin_date": {
                    "type": "string",
                    "format": "date"
                },
                "answer_date": {
                    "type": "string",
                    "format": "date"
                },
                "return_date": {
                    "anyOf": [
                        {
                            "type": "string",
                            "maxLength": 0
                        },
                        {
                            "type": "string",
                            "format": "date"
                        }
                    ]
                }
            }
        },
        "signatures": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "originator",
                "received_by",
                "answer_by"
            ],
            "properties": {
                "originator": {
                    "$ref": "#/$defs/personWithJobTitle"
                },
                "received_by": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "name",
                        "job_title",
                        "date"
                    ],
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "job_title": {
                            "type": "string"
                        },
                        "date": {
                            "anyOf": [
                                {
                                    "type": "string",
                                    "maxLength": 0
                                },
                                {
                                    "type": "string",
                                    "format": "date"
                                }
                            ]
                        }
                    }
                },
                "answer_by": {
                    "$ref": "#/$defs/personWithJobTitle"
                }
            }
        },
        "answer": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "text"
            ],
            "properties": {
                "text": {
                    "type": "string"
                }
            }
        },
        "metadata": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "revision_date",
                "area",
                "file_label",
                "page"
            ],
            "properties": {
                "revision_date": {
                    "type": "string",
                    "minLength": 1
                },
                "area": {
                    "type": "string",
                    "minLength": 1
                },
                "file_label": {
                    "type": "string",
                    "minLength": 1
                },
                "page": {
                    "type": "string",
                    "pattern": "^[0-9]+ of [0-9]+$"
                }
            }
        }
    },
    "$defs": {
        "personWithEmail": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name",
                "email"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "email": {
                    "type": "string",
                    "format": "email"
                }
            }
        },
        "personWithJobTitle": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name",
                "job_title"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "job_title": {
                    "type": "string"
                }
            }
        },
        "namedSubitem": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "description": {
                    "type": "string"
                },
                "subsubitems": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            }
        },
        "subitem": {
            "oneOf": [
                {
                    "type": "string",
                    "minLength": 1
                },
                {
                    "$ref": "#/$defs/namedSubitem"
                }
            ]
        },
        "rfiItem": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "title"
            ],
            "properties": {
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "description": {
                    "type": "string",
                    "minLength": 1
                },
                "subitems": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/subitem"
                    }
                },
                "subsubitems": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "table_columns": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            },
            "anyOf": [
                {
                    "required": [
                        "description"
                    ]
                },
                {
                    "required": [
                        "subitems"
                    ]
                },
                {
                    "required": [
                        "subsubitems"
                    ]
                },
                {
                    "required": [
                        "table_columns"
                    ]
                }
            ]
        }
    }
}